# Rust build artefacts
/target/
**/*.rs.bk

# Packaging output (scripts/package-nfpm.sh)
/dist/
*.deb
*.rpm
*.pkg.tar.zst

# AUR makepkg working dirs and downloaded sources (per-PKGBUILD dir)
packaging/aur/*/pkg/
packaging/aur/*/src/
packaging/aur/*/checksums.sha256-*

# Ad-hoc backups left by session-auth / manual PAM edits
*.bak
*.orig
*~

# Local logs / temporary working files
*.log
/tmp/
/.tmp/
facegate-*.tmp

# Local-only working notes (publishing checklist, etc.) — see
# PUBLISHING.local.md for what lives here.
*.local.md

# AI-assistant context file (generated per-developer, not part of the project)
CLAUDE.md

# mdBook output (built by .github/workflows/pages.yml in CI)
/docs/book/book/

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
