root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.rs]
indent_size = 4

[*.{toml,yaml,yml,json,md}]
indent_size = 2

[*.sh]
indent_size = 4

[{Makefile,*.mk}]
indent_style = tab

# Markdown: trailing whitespace can be a line-break marker — don't strip it.
[*.md]
trim_trailing_whitespace = false
